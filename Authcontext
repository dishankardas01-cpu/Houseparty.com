import { createContext, useContext, useEffect, useRef, useState } from "react";
import {
  RecaptchaVerifier,
  signInWithPhoneNumber,
  signOut as firebaseSignOut,
  onAuthStateChanged,
} from "firebase/auth";
import { doc, getDoc, onSnapshot, serverTimestamp, setDoc, updateDoc } from "firebase/firestore";
import { auth, db } from "../firebase";

const AuthContext = createContext(null);

export function AuthProvider({ children }) {
  const [user, setUser] = useState(null); // Firebase Auth user
  const [profile, setProfile] = useState(null); // Firestore users/{uid} doc
  const [authLoading, setAuthLoading] = useState(true);
  const [profileLoading, setProfileLoading] = useState(true);
  const recaptchaRef = useRef(null);

  useEffect(() => {
    const unsub = onAuthStateChanged(auth, (u) => {
      setUser(u);
      setAuthLoading(false);
      if (!u) {
        setProfile(null);
        setProfileLoading(false);
      }
    });
    return unsub;
  }, []);

  useEffect(() => {
    if (!user) return;
    setProfileLoading(true);
    const ref = doc(db, "users", user.uid);
    const unsub = onSnapshot(ref, (snap) => {
      setProfile(snap.exists() ? { id: snap.id, ...snap.data() } : null);
      setProfileLoading(false);
    });
    return unsub;
  }, [user]);

  // Invisible reCAPTCHA required by Firebase Phone Auth. Call once, on the
  // page that has the phone number input, before sendOtp().
  function ensureRecaptcha(containerId) {
    if (!recaptchaRef.current) {
      recaptchaRef.current = new RecaptchaVerifier(auth, containerId, {
        size: "invisible",
      });
    }
    return recaptchaRef.current;
  }

  async function sendOtp(phoneNumberE164, containerId) {
    const verifier = ensureRecaptcha(containerId);
    return signInWithPhoneNumber(auth, phoneNumberE164, verifier);
  }

  async function confirmOtp(confirmationResult, code) {
    const result = await confirmationResult.confirm(code);
    const ref = doc(db, "users", result.user.uid);
    const existing = await getDoc(ref);
    if (!existing.exists()) {
      await setDoc(ref, {
        phone: result.user.phoneNumber,
        phoneVerified: true,
        email: null,
        emailVerified: false,
        displayName: "",
        bio: "",
        photoURL: "",
        profileComplete: false,
        createdAt: serverTimestamp(),
      });
    }
    return result.user;
  }

  async function saveProfile(data) {
    if (!user) throw new Error("Not signed in");
    await updateDoc(doc(db, "users", user.uid), data);
  }

  async function logOut() {
    await firebaseSignOut(auth);
  }

  const value = {
    user,
    profile,
    loading: authLoading || (!!user && profileLoading),
    sendOtp,
    confirmOtp,
    saveProfile,
    logOut,
    needsProfile: !!user && !!profile && !profile.profileComplete,
  };

  return <AuthContext.Provider value={value}>{children}</AuthContext.Provider>;
}

export function useAuth() {
  const ctx = useContext(AuthContext);
  if (!ctx) throw new Error("useAuth must be used inside AuthProvider");
  return ctx;
}
